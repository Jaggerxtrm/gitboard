{
  "name": "@omniforge/beadboard",
  "version": "0.1.0",
  "description": "Beads Issue Tracking Dashboard for Omniforge",
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "dev:dashboard": "vite --config vite.config.ts",
    "build": "vite build --config vite.config.ts",
    "build:dashboard": "vite build --config vite.config.ts",
    "start": "bun run src/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@types/bun": "latest",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "happy-dom": "^20.8.3",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "@omniforge/core": "workspace:*",
    "@omniforge/ui": "workspace:*",
    "@primer/octicons-react": "^19.22.0",
    "@radix-ui/react-accordion": "^1.2.12",
    "@radix-ui/react-collapsible": "^1.1.12",
    "@radix-ui/react-tooltip": "^1.2.8",
    "@tanstack/react-virtual": "^3.13.21",
    "hono": "^4.12.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zustand": "^5.0.11"
  }
}
